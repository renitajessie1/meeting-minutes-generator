# Copy this file to .env and fill in your real key. Never commit .env itself.

# Your Gemini API key. Get one from:
# - Google AI Studio (aistudio.google.com) — usually requires billing to be linked
#   for the free-tier quota to actually activate on new keys.
# - OR Vertex AI Express Mode (see README) — does NOT require billing/a card
#   for new users during the 90-day trial. Recommended if you don't have a card.
GEMINI_API_KEY=your_gemini_api_key_here

# Set to "true" if the key above is a Vertex AI Express Mode key.
# Leave as "false" (or remove this line) for a normal AI Studio key.
USE_VERTEX_EXPRESS=false
